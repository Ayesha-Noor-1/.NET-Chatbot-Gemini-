@model List<AIChatbotApp.Models.ChatMessage>
@using AIChatbotApp.Models

@{
    ViewData["Title"] = "AI Chatbot";
    Layout = null;
    var sessions = ViewBag.Sessions as List<ChatSession> ?? new List<ChatSession>();
    var activeSessionId = ViewBag.SessionId as string ?? "";
    var userName = ViewBag.UserName as string ?? "User";
    var userInitial = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Chatbot</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root {
            --bg-primary: #0f0f10;
            --bg-secondary: #1a1a1f;
            --bg-tertiary: #25252d;
            --bg-hover: #2d2d38;
            --accent: #7c6aff;
            --accent-hover: #6857e6;
            --accent-glow: rgba(124, 106, 255, 0.15);
            --text-primary: #f0f0f5;
            --text-secondary: #9090a8;
            --text-muted: #5a5a72;
            --border: #2a2a35;
            --user-bubble: linear-gradient(135deg, #7c6aff, #5b4de0);
            --ai-bubble: #1e1e28;
            --input-bg: #1e1e28;
            --scrollbar: #2a2a38;
            --success: #4ade80;
            --danger: #f87171;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* SIDEBAR */
        .sidebar {
            width: 260px;
            background: var(--bg-secondary);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
        }

        .sidebar-header {
            padding: 20px 16px 16px;
            border-bottom: 1px solid var(--border);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: var(--accent);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            box-shadow: 0 0 16px var(--accent-glow);
        }

        .logo-text {
            font-size: 1rem;
            font-weight: 700;
        }

            .logo-text span {
                color: var(--accent);
            }

        .new-chat-btn {
            width: 100%;
            padding: 10px;
            background: var(--accent);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 0.88rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.2s;
            font-family: 'Inter', sans-serif;
        }

            .new-chat-btn:hover {
                background: var(--accent-hover);
                box-shadow: 0 4px 16px var(--accent-glow);
            }

        .sidebar-section {
            padding: 12px 16px 6px;
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .sidebar-content {
            flex: 1;
            overflow-y: auto;
            padding: 8px;
        }

            .sidebar-content::-webkit-scrollbar {
                width: 4px;
            }

            .sidebar-content::-webkit-scrollbar-thumb {
                background: var(--scrollbar);
                border-radius: 4px;
            }

        .chat-item {
            padding: 10px 12px;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.84rem;
            color: var(--text-secondary);
            transition: all 0.15s;
            margin-bottom: 2px;
            position: relative;
        }

            .chat-item:hover {
                background: var(--bg-hover);
                color: var(--text-primary);
            }

            .chat-item.active {
                background: var(--accent-glow);
                color: var(--text-primary);
                border: 1px solid rgba(124,106,255,0.2);
            }

        .chat-item-title {
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .delete-btn {
            opacity: 0;
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            padding: 2px 4px;
            border-radius: 4px;
            font-size: 0.75rem;
            transition: all 0.15s;
        }

        .chat-item:hover .delete-btn {
            opacity: 1;
        }

        .delete-btn:hover {
            color: var(--danger);
            background: rgba(248,113,113,0.1);
        }

        .sidebar-footer {
            padding: 12px;
            border-top: 1px solid var(--border);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px;
            border-radius: 8px;
        }

        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
            font-weight: 600;
            flex-shrink: 0;
        }

        .user-name {
            font-size: 0.85rem;
            font-weight: 500;
        }

        .user-role {
            font-size: 0.72rem;
            color: var(--text-muted);
        }

        .logout-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 0.85rem;
            padding: 4px 6px;
            border-radius: 6px;
            transition: all 0.15s;
        }

            .logout-btn:hover {
                color: var(--danger);
                background: rgba(248,113,113,0.1);
            }

        /* MAIN */
        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .chat-header {
            padding: 16px 24px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--bg-secondary);
        }

        .chat-title {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            background: var(--success);
            border-radius: 50%;
            box-shadow: 0 0 6px var(--success);
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.4;
            }
        }

        .chat-title h2 {
            font-size: 0.95rem;
            font-weight: 600;
        }

        .chat-subtitle {
            font-size: 0.78rem;
            color: var(--text-muted);
        }

        #chatBox {
            flex: 1;
            overflow-y: auto;
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

            #chatBox::-webkit-scrollbar {
                width: 5px;
            }

            #chatBox::-webkit-scrollbar-thumb {
                background: var(--scrollbar);
                border-radius: 4px;
            }

        .welcome-screen {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            flex: 1;
            text-align: center;
            padding: 40px;
            gap: 16px;
        }

        .welcome-icon {
            width: 64px;
            height: 64px;
            background: var(--accent-glow);
            border: 1px solid var(--accent);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            box-shadow: 0 0 32px var(--accent-glow);
        }

        .welcome-screen h2 {
            font-size: 1.4rem;
            font-weight: 700;
        }

        .welcome-screen p {
            color: var(--text-secondary);
            font-size: 0.9rem;
            max-width: 360px;
            line-height: 1.6;
        }

        .suggestion-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: center;
            margin-top: 8px;
        }

        .chip {
            padding: 8px 16px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border);
            border-radius: 20px;
            font-size: 0.82rem;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.15s;
            font-family: 'Inter', sans-serif;
        }

            .chip:hover {
                background: var(--accent-glow);
                border-color: var(--accent);
                color: var(--text-primary);
            }

        .message-row {
            display: flex;
            gap: 12px;
            align-items: flex-start;
            animation: fadeIn 0.3s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .message-row.user {
            flex-direction: row-reverse;
        }

        .msg-avatar {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            font-weight: 600;
            flex-shrink: 0;
        }

            .msg-avatar.ai {
                background: var(--accent);
                box-shadow: 0 0 12px var(--accent-glow);
            }

            .msg-avatar.user {
                background: var(--bg-tertiary);
                border: 1px solid var(--border);
            }

        .message-content {
            max-width: 70%;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .message-row.user .message-content {
            align-items: flex-end;
        }

        .sender-name {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 500;
            padding: 0 4px;
        }

        .bubble {
            padding: 12px 16px;
            border-radius: 16px;
            font-size: 0.9rem;
            line-height: 1.65;
            word-wrap: break-word;
        }

            .bubble.user {
                background: var(--user-bubble);
                color: white;
                border-bottom-right-radius: 4px;
            }

            .bubble.ai {
                background: var(--ai-bubble);
                color: var(--text-primary);
                border: 1px solid var(--border);
                border-bottom-left-radius: 4px;
            }

        .msg-time {
            font-size: 0.7rem;
            color: var(--text-muted);
            padding: 0 4px;
        }

        .typing-row {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .typing-bubble {
            background: var(--ai-bubble);
            border: 1px solid var(--border);
            border-radius: 16px;
            border-bottom-left-radius: 4px;
            padding: 14px 18px;
            display: flex;
            gap: 5px;
            align-items: center;
        }

        .dot {
            width: 7px;
            height: 7px;
            background: var(--accent);
            border-radius: 50%;
            animation: bounce 1.2s infinite;
        }

            .dot:nth-child(2) {
                animation-delay: 0.2s;
            }

            .dot:nth-child(3) {
                animation-delay: 0.4s;
            }

        @@keyframes bounce {
            0%, 60%, 100% {
                transform: translateY(0);
            }

            30% {
                transform: translateY(-6px);
            }
        }

        #errorBox {
            margin: 0 24px 8px;
            padding: 10px 16px;
            background: rgba(248,113,113,0.1);
            border: 1px solid rgba(248,113,113,0.3);
            color: var(--danger);
            border-radius: 10px;
            font-size: 0.85rem;
            display: none;
            align-items: center;
            gap: 8px;
        }

        .input-area {
            padding: 16px 24px 20px;
            border-top: 1px solid var(--border);
            background: var(--bg-secondary);
        }

        .input-wrapper {
            display: flex;
            gap: 10px;
            align-items: flex-end;
            background: var(--input-bg);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 10px 10px 10px 16px;
            transition: border-color 0.2s;
        }

            .input-wrapper:focus-within {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px var(--accent-glow);
            }

        #messageInput {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: var(--text-primary);
            font-size: 0.92rem;
            font-family: 'Inter', sans-serif;
            resize: none;
            max-height: 120px;
            line-height: 1.5;
        }

            #messageInput::placeholder {
                color: var(--text-muted);
            }

        #sendBtn {
            width: 38px;
            height: 38px;
            background: var(--accent);
            border: none;
            border-radius: 10px;
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            transition: all 0.2s;
            flex-shrink: 0;
        }

            #sendBtn:hover {
                background: var(--accent-hover);
                box-shadow: 0 4px 12px var(--accent-glow);
            }

            #sendBtn:disabled {
                background: var(--bg-tertiary);
                color: var(--text-muted);
                cursor: not-allowed;
            }

        .input-hint {
            text-align: center;
            font-size: 0.72rem;
            color: var(--text-muted);
            margin-top: 8px;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <div class="logo-icon">🤖</div>
                <div class="logo-text">AI<span>Chat</span></div>
            </div>
            <button class="new-chat-btn" onclick="newChat()">
                <i class="fas fa-plus"></i> New Chat
            </button>
        </div>

        <div class="sidebar-section">Recent Chats</div>
        <div class="sidebar-content" id="sessionList">
            @if (!sessions.Any())
            {
                <div class="chat-item active" id="current-@activeSessionId">
                    <i class="fas fa-message" style="font-size:0.8rem;flex-shrink:0"></i>
                    <span class="chat-item-title">New Chat</span>
                </div>
            }
            else
            {
                foreach (var session in sessions)
                {
                    <div class="chat-item @(session.Id == activeSessionId ? "active" : "")"
                         id="session-@session.Id"
                         onclick="switchSession('@session.Id')">
                        <i class="fas fa-message" style="font-size:0.8rem;flex-shrink:0"></i>
                        <span class="chat-item-title">@session.Title</span>
                        <button class="delete-btn" onclick="deleteSession(event, '@session.Id')" title="Delete">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                }
            }
        </div>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="avatar">@userInitial</div>
                <div style="flex:1">
                    <div class="user-name">@userName</div>
                    <div class="user-role">Free Plan</div>
                </div>
                <form method="post" action="/Account/Logout" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn" title="Logout">
                        <i class="fas fa-sign-out-alt"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- MAIN -->
    <div class="main">
        <div class="chat-header">
            <div class="chat-title">
                <div class="status-dot"></div>
                <div>
                    <h2>Gemini AI Assistant</h2>
                    <div class="chat-subtitle">Powered by OpenRouter</div>
                </div>
            </div>
        </div>

        <div id="chatBox">
            @if (Model == null || !Model.Any())
            {
                <div class="welcome-screen" id="welcomeScreen">
                    <div class="welcome-icon">🤖</div>
                    <h2>How can I help you today?</h2>
                    <p>Ask me anything — I'm your AI assistant powered by advanced language models.</p>
                    <div class="suggestion-chips">
                        <button class="chip" onclick="sendChip(this)">✍️ Write an essay</button>
                        <button class="chip" onclick="sendChip(this)">💻 Help me code</button>
                        <button class="chip" onclick="sendChip(this)">📖 Explain a concept</button>
                        <button class="chip" onclick="sendChip(this)">🌍 Translate text</button>
                    </div>
                </div>
            }
            else
            {
                foreach (var msg in Model)
                {
                    <div class="message-row @msg.Role">
                        <div class="msg-avatar @(msg.Role == "user" ? "user" : "ai")">
                            @(msg.Role == "user" ? @userInitial : "🤖")
                        </div>
                        <div class="message-content">
                            <div class="sender-name">@(msg.Role == "user" ? userName : "AI Assistant")</div>
                            <div class="bubble @(msg.Role == "user" ? "user" : "ai")">@msg.Content</div>
                            <div class="msg-time">@msg.Timestamp.ToString("hh:mm tt")</div>
                        </div>
                    </div>
                }
            }
        </div>

        <div id="errorBox"><i class="fas fa-circle-exclamation"></i><span id="errorText"></span></div>

        <div class="input-area">
            <div class="input-wrapper">
                <textarea id="messageInput" rows="1"
                          placeholder="Message AI Assistant... (Enter to send)"></textarea>
                <button id="sendBtn"><i class="fas fa-paper-plane"></i></button>
            </div>
            <div class="input-hint">AI can make mistakes. Verify important information.</div>
        </div>
    </div>

    <script>
        let activeSessionId = '@activeSessionId';

        const chatBox = document.getElementById('chatBox');
        const input = document.getElementById('messageInput');
        const sendBtn = document.getElementById('sendBtn');
        const errorBox = document.getElementById('errorBox');

        input.addEventListener('input', function () {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        });

        input.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
        });

        sendBtn.addEventListener('click', sendMessage);

        function sendChip(btn) {
            input.value = btn.textContent.replace(/^.{2}/, '').trim();
            sendMessage();
        }

        async function sendMessage() {
            const message = input.value.trim();
            if (!message) return;

            hideError();
            document.getElementById('welcomeScreen')?.remove();
            appendMessage('user', message);
            input.value = '';
            input.style.height = 'auto';
            sendBtn.disabled = true;

            const typingRow = document.createElement('div');
            typingRow.className = 'typing-row';
            typingRow.id = 'typing';
            typingRow.innerHTML = `<div class="msg-avatar ai">🤖</div>
                <div class="typing-bubble">
                    <div class="dot"></div><div class="dot"></div><div class="dot"></div>
                </div>`;
            chatBox.appendChild(typingRow);
            scrollToBottom();

            try {
                const response = await fetch('/Chat/Send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message, sessionId: activeSessionId })
                });

                const data = await response.json();

                if (!response.ok) {
                    showError(data.error || 'Something went wrong.');
                } else {
                    appendMessage('assistant', data.reply);
                    // Update sidebar title after first message
                    updateSessionTitle(activeSessionId, message);
                }
            } catch {
                showError('Network error. Please check your connection.');
            } finally {
                document.getElementById('typing')?.remove();
                sendBtn.disabled = false;
                scrollToBottom();
            }
        }

        async function newChat() {
            const res = await fetch('/Chat/NewChat', { method: 'POST' });
            const data = await res.json();
            activeSessionId = data.sessionId;

            // Add to sidebar
            const list = document.getElementById('sessionList');
            const div = document.createElement('div');
            div.className = 'chat-item active';
            div.id = `session-${data.sessionId}`;
            div.onclick = () => switchSession(data.sessionId);
            div.innerHTML = `<i class="fas fa-message" style="font-size:0.8rem;flex-shrink:0"></i>
                <span class="chat-item-title">New Chat</span>
                <button class="delete-btn" onclick="deleteSession(event, '${data.sessionId}')" title="Delete">
                    <i class="fas fa-trash"></i>
                </button>`;

            // Deactivate others
            document.querySelectorAll('.chat-item').forEach(i => i.classList.remove('active'));
            list.insertBefore(div, list.firstChild);

            // Clear chat area
            chatBox.innerHTML = `<div class="welcome-screen" id="welcomeScreen">
                <div class="welcome-icon">🤖</div>
                <h2>How can I help you today?</h2>
                <p>Ask me anything — I'm your AI assistant.</p>
                <div class="suggestion-chips">
                    <button class="chip" onclick="sendChip(this)">✍️ Write an essay</button>
                    <button class="chip" onclick="sendChip(this)">💻 Help me code</button>
                    <button class="chip" onclick="sendChip(this)">📖 Explain a concept</button>
                    <button class="chip" onclick="sendChip(this)">🌍 Translate text</button>
                </div>
            </div>`;
            hideError();
        }

        async function switchSession(sessionId) {
            if (sessionId === activeSessionId) return;

            const res = await fetch('/Chat/SwitchSession', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sessionId })
            });

            const data = await res.json();
            activeSessionId = sessionId;

            // Update active state in sidebar
            document.querySelectorAll('.chat-item').forEach(i => i.classList.remove('active'));
            document.getElementById(`session-${sessionId}`)?.classList.add('active');

            // Render messages
            chatBox.innerHTML = '';
            if (!data.messages || data.messages.length === 0) {
                chatBox.innerHTML = `<div class="welcome-screen" id="welcomeScreen">
                    <div class="welcome-icon">🤖</div>
                    <h2>How can I help you today?</h2>
                    <p>Ask me anything.</p>
                </div>`;
            } else {
                data.messages.forEach(m => appendMessage(m.role, m.content, m.timestamp));
            }
            scrollToBottom();
        }

        async function deleteSession(event, sessionId) {
            event.stopPropagation();
            if (!confirm('Delete this chat?')) return;

            const res = await fetch('/Chat/DeleteSession', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sessionId })
            });

            const data = await res.json();
            document.getElementById(`session-${sessionId}`)?.remove();

            if (sessionId === activeSessionId) {
                activeSessionId = data.nextSessionId;
                await switchSession(activeSessionId);
            }
        }

        function updateSessionTitle(sessionId, firstMessage) {
            const item = document.getElementById(`session-${sessionId}`);
            if (item) {
                const titleEl = item.querySelector('.chat-item-title');
                if (titleEl && titleEl.textContent === 'New Chat') {
                    titleEl.textContent = firstMessage.length > 28
                        ? firstMessage.substring(0, 28) + '...'
                        : firstMessage;
                }
            }
        }

        function appendMessage(role, content, timestamp) {
            const isUser = role === 'user';
            const time = timestamp
                ? new Date(timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
                : new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            const div = document.createElement('div');
            div.className = `message-row ${role}`;
            div.innerHTML = `
                <div class="msg-avatar ${isUser ? 'user' : 'ai'}">${isUser ? '@userInitial' : '🤖'}</div>
                <div class="message-content">
                    <div class="sender-name">${isUser ? '@userName' : 'AI Assistant'}</div>
                    <div class="bubble ${isUser ? 'user' : 'ai'}">${escapeHtml(content)}</div>
                    <div class="msg-time">${time}</div>
                </div>`;
            chatBox.appendChild(div);
        }

        function escapeHtml(text) {
            return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');
        }

        function scrollToBottom() { chatBox.scrollTop = chatBox.scrollHeight; }
        function showError(msg) { document.getElementById('errorText').textContent = msg; errorBox.style.display = 'flex'; }
        function hideError() { errorBox.style.display = 'none'; }
    </script>
</body>
</html>